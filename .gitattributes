# Normalize line endings to LF on commit, checkout as native
* text=auto

# Force LF for these file types
*.kt text eol=lf
*.kts text eol=lf
*.java text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.properties text eol=lf
*.pro text eol=lf
*.cfg text eol=lf
*.toml text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.jar binary
*.aar binary
*.apk binary
*.aab binary
*.jks binary
*.keystore binary
