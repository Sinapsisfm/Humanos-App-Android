<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Matches ApkInstaller's getExternalFilesDir(DIRECTORY_DOWNLOADS), i.e.
         <app files>/Download/. Lets the FileProvider share the downloaded APK
         with the system installer. -->
    <external-files-path name="apk_downloads" path="Download/" />
</paths>
